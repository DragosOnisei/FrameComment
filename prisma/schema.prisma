// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // 2.1.2+: explicit binary targets so Prisma generates query
  // engines for BOTH the alpine builder (musl) and the debian
  // runner (glibc). Without these, `prisma generate` only
  // builds the "native" target = whatever distro is doing the
  // generation = alpine musl, and the runtime fails to load
  // the engine with cryptic "Query engine not found" or silent
  // db-connect failures (PostgreSQL is up + healthy but Prisma
  // can't open it). Keep both entries while we ship a
  // multi-distro image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?  @unique
  password  String
  name      String?
  // 2.5.1+: Profile avatar — stored inline as a `data:` URL so we
  // don't need a separate object store / S3 bucket. Capped on the
  // client side to ~256×256px JPEG, ~150KB, which keeps the column
  // small enough for routine session lookups. Nullable: falls back
  // to initials-on-disc when missing.
  avatarUrl String?
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects          Project[]
  comments          Comment[]
  markers           Marker[]
  passkeys          PasskeyCredential[]
  pushSubscriptions PushSubscription[]
  calendarToken     CalendarToken?
  foldersCreated    Folder[]            @relation("FolderCreator")
  folderDocuments   FolderDocument[]    @relation("FolderDocumentCreator")
  // Admin user who uploaded each video — shown as the "uploader"
  // in the Frame.io-style folder grid (1.0.6+). Nullable so any
  // historical pre-1.0.6 rows still load.
  videosCreated     Video[]             @relation("VideoCreator")
  // 3.5.0+: in-app bell notifications addressed to this admin.
  notifications     Notification[]      @relation("UserNotifications")
}

enum UserRole {
  ADMIN
}

model Project {
  id              String  @id @default(cuid())
  title           String
  slug            String  @unique
  description     String?
  companyName     String? // Optional company/brand name (display priority: companyName → primary recipient → 'Client')
  sharePassword   String?
  authMode        String  @default("PASSWORD") // Authentication mode: PASSWORD, OTP, BOTH, or NONE
  // 1.4.x+: optional share-link expiration. NULL = never expires
  // (default). When set, public share routes return 410 Gone after
  // this timestamp and the share page shows a "Expires in N days"
  // banner so the client knows the cut-off date.
  shareExpiresAt  DateTime?
  guestMode       Boolean @default(false) // Allow guest access with limited view (videos only, no comments/approval)
  guestLatestOnly Boolean @default(true) // Guests can only view latest version of each video

  // 1.2.0+: optional cover image displayed on the project card in
  // place of the deterministic gradient. Stored as a path within the
  // storage abstraction (`projects/{id}/cover.{ext}`). Null means the
  // dashboard falls back to the gradient default.
  coverImagePath  String?

  // 1.2.0+: soft-delete column matching the Video / Folder pattern.
  // A daily cleanup job hard-deletes projects whose deletedAt is older
  // than TRASH_RETENTION_DAYS (30). Listings filter `deletedAt IS NULL`
  // so trashed projects only show up on the dedicated Trash page.
  deletedAt       DateTime?

  // Revision tracking (optional)
  enableRevisions Boolean @default(false)
  maxRevisions    Int     @default(3)

  status          ProjectStatus @default(IN_REVIEW)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  approvedAt      DateTime?
  approvedVideoId String? // ID of the video that was approved (null if not approved)

  // Comment restrictions
  restrictCommentsToLatestVersion Boolean @default(false)
  hideFeedback                    Boolean @default(false)

  // Comment timestamp display for this project (stored at creation; editable per project)
  // AUTO = MM:SS or HH:MM:SS based on video length, TIMECODE = HH:MM:SS:FF (or DF)
  timestampDisplay String @default("TIMECODE")

  // Video processing settings
  previewResolution String  @default("auto") // "auto" | "720p" | "1080p" | "2160p". The ladder always starts at 480p (the fast first tier) and climbs to whatever cap is set here. "auto" matches the source — a 1080p input gets the full 480→720→1080 ladder, a 4K input gets all four, a 720p input stops at 720p. The three explicit values stay for users who want a CPU / storage ceiling on big sources.
  skipTranscoding   Boolean @default(false) // Skip transcoding entirely — serve original file directly
  watermarkEnabled  Boolean @default(true) // Enable/disable watermarks for this project
  watermarkText     String? // Custom watermark text (null = use default format)
  watermarkPositions String  @default("center") // comma-separated: center, top-left, top-right, bottom-left, bottom-right
  watermarkOpacity   Int     @default(30) // Opacity percentage (10-100)
  watermarkFontSize  String  @default("medium") // small, medium, large
  applyPreviewLut      Boolean @default(false) // 1.9.4+ Phase A: LUT off by default for ALL videos — the color-calibration filter ran at INPUT resolution before the downscale, adding 30-60 s per tier on a 40-min source for visual benefit the typical reviewer never asks for. Operators who actually want color-calibrated previews can opt in per-project.

  // Client share page settings
  allowAssetDownload     Boolean @default(true) // Allow clients to download video assets when project is approved
  allowClientAssetUpload Boolean @default(true) // Allow clients to upload file attachments on comments (1.9.1+: default true; admin can disable per project)
  clientCanApprove       Boolean @default(true) // Allow clients to approve videos (false = admin only)
  allowReverseShare      Boolean @default(false) // Allow clients to upload files directly to the project (reverse share)

  // Approved playback settings
  usePreviewForApprovedPlayback Boolean @default(false) // Use browser-compatible preview instead of original after approval

  // Client tutorial
  showClientTutorial Boolean @default(true) // Show interactive tutorial overlay for first-time visitors

  // Due date tracking
  dueDate     DateTime? // Optional project deadline
  dueReminder String?   // NONE, DAY_BEFORE, WEEK_BEFORE

  // Client notification settings (per-project)
  // Note: Approval emails are always IMMEDIATE regardless of this setting
  clientNotificationSchedule String    @default("HOURLY") // IMMEDIATE, HOURLY, DAILY, WEEKLY
  clientNotificationTime     String? // "09:00" for daily, "Monday 09:00" for weekly
  clientNotificationDay      Int? // 0-6 for weekly (0 = Sunday)
  lastClientNotificationSent DateTime?

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  // Client directory link (optional)
  clientCompanyId String?
  clientCompany   ClientCompany? @relation(fields: [clientCompanyId], references: [id], onDelete: SetNull)

  videos            Video[]
  folders           Folder[] // Optional folder tree inside the project (1.0.6+)
  folderDocuments   FolderDocument[]
  comments          Comment[]
  markers           Marker[]
  securityEvents    SecurityEvent[]
  analytics         VideoAnalytics[]
  recipients        ProjectRecipient[] // Multiple email recipients
  notificationQueue NotificationQueue[] // Pending notifications
  notifications     Notification[] // 3.5.0+: in-app bell notifications
  sharePageAccesses SharePageAccess[] // Share page authentication tracking
  projectUploads    ProjectUpload[] // Client-submitted files via reverse share

  @@index([clientCompanyId])
}

/// Frame.io-style folder inside a project. Folders can be nested
/// arbitrarily deep (parentFolderId is a self-relation). Each folder
/// carries its own share configuration so it can be shared
/// independently from the parent project: a unique slug + the same
/// auth modes (NONE / PASSWORD / OTP / BOTH) the project supports.
///
/// Videos can sit either directly under a project (folderId = null) or
/// inside a folder (folderId set). When a folder is deleted its
/// subfolders are cascaded; videos inside have their folderId set to
/// null (preserved at project root) — that's safer than data loss.
model Folder {
  id             String   @id @default(cuid())
  projectId      String
  parentFolderId String?
  name           String

  // Sharing — mirrors the Project share fields. We default authMode
  // to NONE since the common case is "send the link to a client";
  // admins can lock it down per-folder when they want stricter rules.
  slug          String  @unique
  sharePassword String?
  authMode      String  @default("NONE") // PASSWORD | OTP | BOTH | NONE
  // 1.4.x+: optional share-link expiration on the folder share.
  // NULL = never expires (default). After this timestamp, public
  // /share/folder/[slug] returns 410 Gone.
  shareExpiresAt DateTime?

  // Comment range / visibility settings will live on the project for
  // now; revisit per-folder overrides in a later release if needed.

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  // Soft-delete timestamp (1.0.8+). Same semantics as Video — set to
  // mark a folder as trashed without losing its rows. Cascading is
  // application-level: deleting a folder marks its descendants too,
  // so a restore lifts the whole subtree back at once.
  deletedAt DateTime?

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentFolder Folder?  @relation("FolderHierarchy", fields: [parentFolderId], references: [id], onDelete: Cascade)
  subfolders   Folder[] @relation("FolderHierarchy")
  videos       Video[]
  documents    FolderDocument[]
  createdBy    User?    @relation("FolderCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([parentFolderId])
  @@index([deletedAt])
}

// 3.9.x: a non-video FILE that lives inside a folder (or the project
// root when `folderId` is null). Introduced for the "Create Transcript"
// feature — the worker drops a timecoded transcript PDF here — but the
// model is generic enough for any future document/file item. This is
// what lets a folder hold something OTHER than videos + subfolders.
model FolderDocument {
  id          String @id @default(cuid())
  projectId   String
  folderId    String? // null = project root
  name        String // display name, e.g. "Clip v3 — Transcript.pdf"
  storagePath String // path in the storage layer
  storageBackend String? // 4.2.0+: local|fc|r2|aws (NULL = legacy env)
  storageLocations String? // 4.2.0+ (2b): all backends holding a copy (comma-separated)
  mimeType    String @default("application/pdf")
  size        BigInt @default(0)
  // What produced this document. "transcript" for the whisper flow;
  // room for "note", "export", etc. later.
  kind        String @default("transcript")
  // The video this was generated from, when applicable. SetNull so the
  // document survives if the source version is later deleted.
  sourceVideoId String?

  // 3.9.x: soft-delete — same semantics as Video/Folder. Deleting a
  // document card moves it to Trash (restorable) instead of nuking it.
  deletedAt DateTime?

  createdAt   DateTime @default(now())
  createdById String?

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder      Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)
  sourceVideo Video?  @relation("VideoTranscripts", fields: [sourceVideoId], references: [id], onDelete: SetNull)
  createdBy   User?   @relation("FolderDocumentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([folderId])
  @@index([sourceVideoId])
  @@index([deletedAt])
}

enum ProjectStatus {
  IN_REVIEW
  APPROVED
  SHARE_ONLY
  ARCHIVED
}

model ProjectRecipient {
  id                   String   @id @default(cuid())
  projectId            String
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email                String?
  name                 String?
  isPrimary            Boolean  @default(false)
  receiveNotifications Boolean  @default(true) // Per-recipient notification toggle
  createdAt            DateTime @default(now())

  @@index([projectId])
  @@index([projectId, email])
}

model Video {
  id           String @id @default(cuid())
  projectId    String
  // Optional folder the video lives inside. Null means the video sits
  // directly at the project root (legacy / simple projects). Folders
  // are introduced in 1.0.6; existing rows migrate as folderId = null.
  folderId     String?
  name         String // Name to distinguish different videos in a project (required)
  version      Int // 1, 2, 3 (for revisions)
  versionLabel String // "v1", "v2", "v3" or custom

  // Original file
  originalFileName    String
  originalFileSize    BigInt
  originalStoragePath String

  // 4.2.0+: which storage backend holds this video's files
  // (local | fc | r2 | aws). NULL = legacy env backend (STORAGE_PROVIDER),
  // so pre-4.2.0 rows keep resolving to their original location.
  storageBackend String?
  // 4.2.0+ (Phase 2b): comma-separated list of every backend this file
  // physically lives on (e.g. "local,aws" after a keep-source transfer).
  // NULL/empty = single location (== storageBackend). Display-only; reads
  // always resolve via storageBackend (the active/target backend).
  storageLocations String?

  // Media type (1.0.9+). Default VIDEO so all existing rows stay
  // unchanged after the migration; IMAGE skips the FFmpeg pipeline.
  mediaType MediaType @default(VIDEO)

  // Video metadata
  // For IMAGE rows `duration` is always 0 (kept non-nullable so we
  // don't have to relax every consumer that expects a number) and
  // fps/codec are null.
  duration Float // in seconds
  width    Int
  height   Int
  fps      Float?
  codec    String?

  // Processing status
  status             VideoStatus @default(UPLOADING)
  uploadProgress     Int         @default(0) // 0-100 percentage
  processingProgress Float       @default(0)
  processingError    String?

  // Preview versions (watermarked).
  // 1.9.4+ Phase A: preview480Path is the lowest progressive tier —
  // fastest to encode, first to land, flips the video to READY in
  // under a minute on most inputs. Higher tiers (720/1080/2160)
  // populate progressively as the worker climbs the ladder.
  preview2160Path String?
  preview1080Path String?
  preview720Path  String?
  preview480Path  String?

  // 1.9.4+ Phase B: HLS adaptive-streaming variants. The worker
  // remuxes each MP4 tier into HLS segments + playlist after the
  // tier completes — zero re-encoding penalty, just splits the
  // existing bytes. `hlsBasePath` points to the storage prefix
  // (e.g. `projects/<id>/videos/<id>/hls/`) and `hlsQualities`
  // lists the tiers ready for streaming (e.g. ["480p", "720p"]).
  // The master.m3u8 manifest is generated on-the-fly by the API,
  // listing only the qualities present in `hlsQualities` — so
  // when 1080p lands mid-playback, the player's next manifest
  // poll picks it up and auto-upgrades without restarting.
  hlsBasePath  String?
  hlsQualities String[] @default([])
  // 1.9.4+ Phase B: per-tier transcode progress. JSON map keyed
  // by tier name (e.g. `{"720p": 45, "1080p": 23}`). Updated by
  // the worker's ffmpeg onProgress callback using an atomic
  // `jsonb_set` so two parallel tiers can write to it without
  // clobbering each other. The single `processingProgress` field
  // above only tracks the worker's coarse overall progress and
  // gets overwritten by whichever ffmpeg races last — this map
  // is what the Quality menu's per-row percentage reads from.
  transcodeProgressByTier Json @default("{}")
  // 2.2.0+: breadth-first encoding tier tracking.
  //
  // `prepare-video` writes `plannedTiers` once (e.g.
  // ["480p","720p","1080p","2160p"]) right after probing the
  // source so we know up-front which tiers will land. Each
  // `encode-tier` job appends its slug to `completedTiers` on
  // success — that's how `finalize-video` knows the encode ladder
  // is finished, and how the UI tells "we're still climbing"
  // apart from "everything that will ever land has landed".
  //
  // Both columns are nullable for backwards compat: rows produced
  // by the pre-2.2.0 single-job orchestrator never wrote these
  // fields and stay null. Readers MUST treat `null` as "trust
  // legacy preview*Path columns + status" instead of "no tiers
  // planned/done" — see VideoCard + ProcessingStatusBanners.
  plannedTiers   Json?
  completedTiers Json?
  thumbnailPath   String?
  // Hover-scrub storyboard (1.0.6+). A single tiny JPEG packing 100
  // evenly-spaced frames in a 10×10 grid. The folder grid uses CSS
  // background-position on this sprite for instant frame-accurate
  // scrubbing — same approach Frame.io uses.
  storyboardPath  String?

  // Clean (non-watermarked) previews for approved playback
  cleanPreview2160Path String?
  cleanPreview1080Path String?
  cleanPreview720Path  String?

  // Per-video approval
  approved   Boolean   @default(false)
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Admin who uploaded the video (1.0.6+). Optional + SetNull so an
  // admin can be deleted without orphaning their uploads.
  createdById String?

  // Soft-delete timestamp (1.0.8+). When set, the video lives in the
  // Trash for 30 days before a daily cleanup job removes it for
  // good. Listings filter `deletedAt: null` so deleted rows simply
  // disappear from the grids and shares.
  deletedAt DateTime?

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder    Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdBy User?            @relation("VideoCreator", fields: [createdById], references: [id], onDelete: SetNull)
  analytics VideoAnalytics[]
  assets    VideoAsset[]
  transcripts FolderDocument[] @relation("VideoTranscripts")
  comments  Comment[]
  markers   Marker[]
  // 3.5.0+: in-app bell notifications that deep-link to this video.
  notifications Notification[]

  @@index([projectId, version])
  @@index([projectId, name])
  @@index([folderId])
  @@index([createdById])
  @@index([deletedAt])
}

model VideoAsset {
  id      String @id @default(cuid())
  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  // File information
  fileName    String // Original filename (e.g., "project.prproj", "music.mp3", "photo.jpg")
  fileSize    BigInt
  fileType    String // MIME type (e.g., "application/octet-stream", "image/jpeg", "audio/mpeg")
  storagePath String // Path in storage system
  storageBackend String? // 4.2.0+: local|fc|r2|aws (NULL = legacy env)
  storageLocations String? // 4.2.0+ (2b): all backends holding a copy (comma-separated)
  category    String? // Optional category: "image", "audio", "project", "other"

  // Upload metadata
  uploadedBy     String? // User ID or "client" for client uploads
  uploadedByName String? // Display name of uploader
  uploadedBySessionId String? // Stable share/admin session identifier for pending asset ownership

  uploadCompletedAt DateTime? // null until file transfer finishes; orphaned records stay null

  // Comment attachment (optional link to comment)
  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([videoId])
  @@index([videoId, category])
  @@index([videoId, uploadCompletedAt])
  @@index([videoId, uploadedBySessionId])
  @@index([commentId])
}

// Client-submitted files via the reverse share feature (project-level, not attached to a video)
model ProjectUpload {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fileName    String
  fileSize    BigInt
  fileType    String  @default("application/octet-stream")
  storagePath String
  storageBackend String? // 4.2.0+: local|fc|r2|aws (NULL = legacy env)
  storageLocations String? // 4.2.0+ (2b): all backends holding a copy (comma-separated)
  category    String?

  uploadedBySessionId String?
  uploadedByName      String?
  uploadedByEmail     String?

  uploadCompletedAt DateTime? // null until file transfer finishes; orphaned records stay null

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, createdAt])
  @@index([projectId, uploadCompletedAt])
  @@index([uploadedBySessionId])
}

enum VideoStatus {
  UPLOADING
  PROCESSING
  READY
  ERROR
}

// MediaType (1.0.9+). Distinguishes a real video upload (default)
// from an image asset. Images skip the FFmpeg transcode + storyboard
// pipeline entirely and land at READY almost immediately. We reuse
// the Video model rather than a separate Asset entity so folders,
// comments, share links, soft delete, etc. all keep working out of
// the box.
enum MediaType {
  VIDEO
  IMAGE
}

model Comment {
  id           String   @id @default(cuid())
  projectId    String
  videoId      String // All comments must be video-specific
  videoVersion Int? // track which version this comment was for
  timecode     String // HH:MM:SS:FF format (e.g., "00:00:32:15" for 32 seconds 15 frames at given FPS)
  // Sub-second precision moment the comment was left on the video, in
  // milliseconds (Math.round(currentTime * 1000)). Used as the source of
  // truth for click-to-seek so the playhead lands exactly where the comment
  // was made, instead of snapping to the nearest frame boundary derived
  // from `timecode`. Optional for backward compatibility with comments
  // created before 1.0.3.
  timestampMs  Int?
  content      String
  authorName   String? // made optional to allow anonymous comments
  authorEmail  String?
  isInternal   Boolean  @default(false) // true = from studio, false = from client
  // 3.8.x: true when this comment was pasted in from another version via
  // Copy/Paste comments. Surfaces a "Copied" tag in the thread so reviewers
  // can tell carried-over notes apart from fresh ones.
  isCopied     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Annotation support
  timecodeEnd String? // Optional end timecode for time range comments
  annotations Json?   // JSONB storing drawing annotation shapes

  // Admin user tracking (for internal comments)
  userId String? // Admin user who created this comment
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Editor identity for self-edit authorization on the share page.
  // Stores the share-token session id of the original author. On edit,
  // the request must come from the same session to be authorized.
  // Null for admin-authored comments (they edit via admin auth).
  editorSessionId String?

  // Admin reply functionality
  parentId String? // if this is a reply to another comment
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  // 1.2.0+: Frame.io-style "Mark as done" workflow. Any viewer can flip
  // a comment to resolved (and unresolve it), and the timeline + thread
  // gray it out so reviewers can focus on what's still actionable.
  // `resolvedBy` stores the display name (anonymous-friendly) so we can
  // surface "Resolved by X" without exposing session ids.
  isResolved Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?

  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  video     Video             @relation(fields: [videoId], references: [id], onDelete: Cascade)
  assets    VideoAsset[]
  reactions CommentReaction[]

  @@index([projectId])
  @@index([videoId])
  @@index([parentId])
  @@index([userId])
  @@index([isResolved])
}

// 4.1.0+: Premiere-style timeline markers. A coloured flag pinned to a
// specific moment of a video version, with an optional text note + author.
// Distinct from the comment "pins" the UI also calls markers: these are
// lightweight navigation bookmarks (jump between them with ↑/↓) rather
// than threaded feedback. Scoped to a video version so a marker left on
// v2 doesn't leak onto v3 (same rule as annotations/comments).
model Marker {
  id           String   @id @default(cuid())
  projectId    String
  videoId      String
  videoVersion Int?
  // Sub-second position on the video, in milliseconds
  // (Math.round(currentTime * 1000)) — the source of truth for
  // click-to-seek + ↑/↓ navigation, same convention as Comment.timestampMs.
  timestampMs  Int
  // One of: red | orange | green | blue.
  color        String   @default("blue")
  // Optional short note shown on hover (the Premiere "marker name").
  label        String?
  authorName   String?
  isInternal   Boolean  @default(false) // true = studio, false = client
  // Admin author (null for share-side / client markers).
  userId          String?
  user            User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Share-token / browser session id of the author, for self-delete
  // authorization on the share page (mirror of Comment.editorSessionId).
  editorSessionId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  video   Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([videoId])
  @@index([userId])
}

// 1.2.0+: Quick emoji reactions on a comment. Frame.io-style — anyone
// viewing the share page (or an admin) can drop a 👍 / ❤️ / 🎬 etc.
// onto a comment, and reactions are grouped by emoji in the UI.
// One reaction per (comment, session, emoji) so toggling is idempotent.
model CommentReaction {
  id         String   @id @default(cuid())
  commentId  String
  emoji      String // The emoji character itself (UTF-8). Keep raw so the
  //               UI doesn't need a lookup table.
  authorName String? // Display name at the time of reaction (anonymous-friendly)
  sessionId  String // share-token session id OR admin user id — used for
  //                de-dupe + revocation. Required so we can always remove
  //                the right row when a viewer clicks again.
  createdAt  DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, sessionId, emoji])
  @@index([commentId])
  @@index([sessionId])
}

model NotificationQueue {
  id        String @id @default(cuid())
  projectId String
  type      String // CLIENT_COMMENT, ADMIN_REPLY

  // Dual tracking for admin vs client notifications
  sentToClients Boolean   @default(false)
  sentToAdmins  Boolean   @default(false)
  clientSentAt  DateTime?
  adminSentAt   DateTime?

  // Retry and failure tracking
  clientAttempts Int     @default(0) // Number of send attempts to clients
  adminAttempts  Int     @default(0) // Number of send attempts to admins
  clientFailed   Boolean @default(false) // Permanently failed to send to clients
  adminFailed    Boolean @default(false) // Permanently failed to send to admins
  lastError      String? // Last error message for debugging

  data      Json // Stores: commentId, videoId, videoName, authorName, content, timestamp, isReply, etc.
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sentToClients])
  @@index([projectId, sentToAdmins])
  @@index([sentToAdmins, createdAt])
  @@index([clientFailed, adminFailed])
}

// 3.5.0+: In-app "internal" notifications shown in the admin bell.
//
// Distinct from `NotificationQueue` (which drives EXTERNAL email /
// push delivery to clients + admins). This table backs the live bell
// in the admin top bar: when a reviewer clicks "Send to editor" on a
// video, we create one row here for the video's uploader
// (`Video.createdById`) and publish it on a Redis channel so the
// editor's bell updates live (SSE) without a page refresh.
//
// Design notes:
//   - One UNREAD row per (recipient, video). Re-sending the same
//     video before the editor reads it just bumps the existing row to
//     the top instead of stacking duplicates (find-or-create in the
//     API). Different videos => different rows (an editor working on
//     several videos can collect several notifications).
//   - `videoName` / `folderId` are denormalized so the bell can build
//     the deep-link (`/admin/projects/<id>/share?video=<name>&folderId=<id>`)
//     and render the row without an extra join.
//   - No "count" column by design — the notification is a signal
//     ("New comments on X"), per the product decision.
model Notification {
  id   String @id @default(cuid())
  // The admin who receives this (the video's uploader / "editor").
  recipientId String
  // Signal type. Only NEW_COMMENTS today; kept as a string so future
  // signals (approvals, mentions, …) don't need a migration.
  type        String @default("NEW_COMMENTS")

  projectId String
  videoId   String
  // Denormalized for display + deep-link without a join. Kept even if
  // the video is later renamed — the link resolves by name, and a
  // stale name is better than a broken bell row.
  videoName String
  folderId  String?

  // Display name of whoever clicked "Send to editor" (client guest
  // name or admin name). Nullable for anonymous reviewers.
  actorName String?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipient User    @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  video     Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)

  // Primary read path: "my unread/recent notifications, newest first".
  @@index([recipientId, isRead, createdAt])
  // Supports the find-or-create dedupe on (recipient, video).
  @@index([recipientId, videoId])
}

model Settings {
  id String @id @default("default")

  // Language / i18n
  language String @default("en") // UI language code (en, nl, de, fr, etc.)

  // Appearance
  defaultTheme String @default("auto") // "light", "dark", or "auto" (system preference)
  accentColor  String @default("blue") // Preset accent color name

  // Company Branding
  companyName String? @default("Studio") // Displayed in feedback/comments
  brandingLogoPath String? // Path to uploaded custom SVG logo
  emailHeaderStyle String @default("LOGO_AND_NAME") // NONE, LOGO_ONLY, NAME_ONLY, LOGO_AND_NAME

  // SMTP Email Configuration
  smtpServer      String?
  smtpPort        Int?    @default(587)
  smtpUsername    String?
  smtpPassword    String?
  smtpFromAddress String?
  smtpSecure      String? @default("STARTTLS") // Options: "STARTTLS", "TLS", "NONE"

  // Domain Configuration
  appDomain String? // e.g., "https://yourdomain.com"
  // 2.4.0+: short-link domain for Frame.io-style URL shortener.
  // When set (e.g. "fcmt.io"), the "Share Video/Folder/Project"
  // flow creates a ShortLink record + returns a tidy URL like
  // `https://fcmt.io/aBc12XyZ` instead of the 200-character signed
  // HMAC URL. The middleware translates `Host: fcmt.io` +
  // `/<slug>` → 302 redirect to the resolved targetUrl. Stored as
  // hostname only, no scheme or path: "fcmt.io" not
  // "https://fcmt.io/". NULL = feature disabled, share modal copies
  // the long URL like pre-2.4.0.
  shortLinkDomain String?

  // 3.9.x: OpenAI API key for the "Create Transcript" feature. The
  // worker extracts a video's audio and sends it to OpenAI's
  // `whisper-1` transcription endpoint, then renders a timecoded PDF
  // into the video's folder. Stored server-side only; never exposed to
  // the client (the settings GET redacts it — see the settings route).
  openaiApiKey String?

  // 4.2.0+: Storage backend selection (multi-backend support).
  //
  //   activeStorageBackend — which backend NEW uploads are written to:
  //     'local' = the app server's own disk (STORAGE_ROOT), no per-GB cost
  //     'fc'    = FrameComment-managed S3 bucket (operator env config),
  //               billed per-GB — this is the product default
  //     'r2'    = the customer's own Cloudflare R2 bucket (config below)
  //     'aws'   = the customer's own AWS S3 bucket (config below)
  //   NULL = legacy behaviour: follow the STORAGE_PROVIDER env var (so
  //   nothing changes until an admin explicitly picks a backend).
  //
  // Existing files keep working regardless — each file row carries its own
  // `storageBackend` (NULL there = the legacy env backend), so reads always
  // resolve to the right place even after the active backend changes.
  activeStorageBackend String?

  // 4.2.0+ (Phase 2d): where the LOCAL backend keeps its uploads folder. NULL =
  // use the STORAGE_ROOT env (default). When set (via the "Local Storage" dialog),
  // new local uploads go here; pre-existing files under STORAGE_ROOT stay readable
  // (the storage layer falls back to the env root on read).
  localStoragePath String?

  // Customer Cloudflare R2 (S3-compatible). Secret is encrypted at rest.
  r2Endpoint          String?
  r2Region            String? @default("auto")
  r2Bucket            String?
  r2AccessKeyId       String?
  r2SecretAccessKey   String? // encrypted via lib/encryption

  // Customer AWS S3. Secret is encrypted at rest.
  awsRegion           String? @default("us-east-1")
  awsBucket           String?
  awsAccessKeyId      String?
  awsSecretAccessKey  String? // encrypted via lib/encryption

  // Default Video Processing Settings
  // 1.9.4+ Phase A: "auto" lets the worker match the source —
  // the progressive ladder always starts at a fast 480p tier and
  // climbs to whatever the source can deliver (no upscaling).
  defaultPreviewResolution  String? @default("auto")
  defaultSkipTranscoding   Boolean @default(false)
  defaultWatermarkEnabled  Boolean @default(true)
  defaultWatermarkText     String?
  defaultWatermarkPositions String  @default("center") // comma-separated: center, top-left, top-right, bottom-left, bottom-right
  defaultWatermarkOpacity   Int     @default(30) // Opacity percentage (10-100)
  defaultWatermarkFontSize  String  @default("medium") // small, medium, large
  defaultApplyPreviewLut      Boolean @default(true) // Apply preview LUT during transcoding by default
  // 1.5.x+: default lifted from 1 GB → 1000 GB (= 1 TB) so video
  // uploads aren't artificially capped on a fresh install; admin can
  // still dial it down from Settings per-instance.
  maxUploadSizeGB          Int      @default(1000) // Maximum file size per upload in GB (1-10000)
  maxCommentAttachments    Int      @default(10) // Maximum files per comment attachment batch (1-50)
  maxReverseShareFiles     Int      @default(99999) // 1.5.8+: pinned to the "unlimited" sentinel — the admin Security tab no longer surfaces a control for this and the operator wants reverse-share to be uncapped per session.

  // Default Comment Timestamp Display
  // TIMECODE = HH:MM:SS:FF (or DF), AUTO = MM:SS or HH:MM:SS based on video length
  defaultTimestampDisplay String @default("TIMECODE")

  // Default Approved Playback Setting
  defaultUsePreviewForApprovedPlayback Boolean @default(false)

  // Default Client Asset Upload Setting
  defaultAllowClientAssetUpload Boolean @default(false)

  // Default Client Access Defaults
  defaultAllowReverseShare  Boolean @default(false) // Default: allow clients to submit files directly to project
  defaultShowClientTutorial Boolean @default(true)  // Default: show interactive tutorial for first-time visitors
  defaultAllowAssetDownload Boolean @default(true)  // Default: allow clients to download approved assets
  defaultClientCanApprove   Boolean @default(true)  // Default: allow clients to approve videos

  // Project Behavior
  autoApproveProject Boolean @default(true) // Auto-approve project when all videos approved

  // Admin notification settings (global)
  // Note: Approval emails and manual admin notifications are always IMMEDIATE regardless of this setting
  adminNotificationSchedule String    @default("HOURLY") // IMMEDIATE, HOURLY, DAILY, WEEKLY
  adminNotificationTime     String? // "09:00" for daily, "Monday 09:00" for weekly
  adminNotificationDay      Int? // 0-6 for weekly (0 = Sunday)
  lastAdminNotificationSent DateTime?

  // Web Push VAPID Keys (auto-generated on first use)
  vapidPublicKey  String? // Public key for browser subscription
  vapidPrivateKey String? // Encrypted private key

  // Privacy Disclosure (shown on client share page)
  privacyDisclosureEnabled Boolean @default(false)
  privacyDisclosureText    String? // Custom text; null = use default i18n text

  // 3.7.0+: Stripe billing (single-account platform model — all money
  // lands in the company's one Stripe account; keys live in env vars).
  stripeCustomerId   String? // Stripe Customer created for this instance
  billingEmail       String? // where Stripe emails invoices/receipts
  paymentMethodBrand String? // saved card brand, e.g. "visa" (UI only)
  paymentMethodLast4 String? // saved card last 4 digits (UI only)
  billingStatus      String    @default("none") // none | active | past_due
  billingAnchorDay   Int? // day-of-month to bill (1-28); null = end of month
  nextBillingAt      DateTime? // next scheduled automatic charge
  lastInvoiceId      String? // most recent Stripe invoice id
  lastInvoiceAmount  Int? // most recent invoice total, in cents
  lastInvoiceStatus  String? // paid | open | uncollectible | void | failed
  lastChargedAt      DateTime? // when the last invoice was charged

  // 3.8.0+: dunning. `billingIssueSince` is set when an unresolved
  // billing problem starts (payment failed, OR over the free tier with
  // no card). After 5 business days unresolved the daily job flips
  // `billingSuspended` — the admin UI shows a billing wall (client
  // share links stay live). Both clear automatically once resolved.
  billingIssueSince DateTime?
  billingSuspended  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * 3.8.0+: daily usage meter. One row per calendar day capturing the
 * instance's user count + total storage bytes. The monthly invoice
 * averages these over the billing period so usage that changes mid-
 * period is prorated correctly (a user added a day before billing pays
 * ~1/30; a user removed the day before still pays for the days used).
 */
model BillingSnapshot {
  id           String   @id @default(cuid())
  day          DateTime @unique // midnight UTC of the snapshot day
  userCount    Int
  storageBytes BigInt
  createdAt    DateTime @default(now())
}

model NotificationDestination {
  id String @id @default(cuid())

  name     String
  enabled  Boolean @default(false)
  provider String // GOTIFY, NTFY, PUSHOVER, TELEGRAM

  // Non-secret provider configuration (e.g. baseUrl, topic, etc.)
  config Json

  // Encrypted JSON string containing secrets (e.g. tokens/keys). Use src/lib/encryption.ts.
  secretsEncrypted String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions NotificationSubscription[]
  deliveries    NotificationDeliveryLog[]

  @@index([provider])
  @@index([enabled])
  @@index([createdAt])
}

model NotificationSubscription {
  id String @id @default(cuid())

  destinationId String
  destination   NotificationDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  eventType String // SHARE_ACCESS, ADMIN_ACCESS, CLIENT_COMMENT, VIDEO_APPROVAL, SECURITY_ALERT
  enabled   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([destinationId, eventType])
  @@index([eventType, enabled])
}

model NotificationDeliveryLog {
  id String @id @default(cuid())

  destinationId String
  destination   NotificationDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  eventType  String
  success    Boolean @default(false)
  statusCode Int?
  error      String?

  sentAt DateTime @default(now())

  @@index([destinationId, sentAt])
  @@index([eventType, sentAt])
  @@index([success, sentAt])
}

model SecuritySettings {
  id String @id @default("default")

  // Hotlink Protection: DISABLED, LOG_ONLY, BLOCK_STRICT
  hotlinkProtection String @default("LOG_ONLY")

  // Rate Limiting (global only - per minute)
  ipRateLimit           Int  @default(1000) // requests per minute per IP (video streaming requires high limit)
  sessionRateLimit      Int  @default(600) // requests per minute per admin session (10/sec for seeking/buffering)
  shareSessionRateLimit Int  @default(300) // requests per minute per share session (client access)
  passwordAttempts      Int  @default(5) // password attempts before lockout
  shareTokenTtlSeconds  Int? // optional override for share JWT expiry (60-86400 seconds, null = use session timeout)

  // Session Timeout (for client share sessions, not admin JWT)
  sessionTimeoutValue Int    @default(15) // Numeric value (15, 30, 1, 2, etc.)
  sessionTimeoutUnit  String @default("MINUTES") // MINUTES, HOURS, DAYS, WEEKS

  // Admin Session Timeout (admin UI inactivity logout)
  // 2.4.2+: default raised from 15 MINUTES → 12 HOURS. Fresh installs
  // now get a workday-length session, matching the actual admin UX
  // (long edit + upload + review sessions). The hard cap at 24 HOURS
  // is unchanged. Existing installs keep their stored value — only
  // freshly-seeded SecuritySettings rows pick this up.
  adminSessionTimeoutValue Int    @default(12) // Numeric value (e.g., 15, 30, 1, 2, etc.)
  adminSessionTimeoutUnit  String @default("HOURS") // MINUTES, HOURS (max 24 hours)

  // HTTPS Enforcement (HTTPS_ENABLED env var always takes precedence if set)
  httpsEnabled Boolean @default(true) // Enable HSTS (default: true for production security)

  // Logging toggles
  trackAnalytics    Boolean @default(true)
  trackSecurityLogs Boolean @default(true)

  // Security Dashboard Access
  viewSecurityEvents Boolean @default(false) // Show /admin/security page in navigation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SecurityEvent {
  id       String @id @default(cuid())
  type     String // HOTLINK_DETECTED, HOTLINK_BLOCKED, RATE_LIMIT_HIT, TOKEN_SESSION_MISMATCH, SUSPICIOUS_ACTIVITY, BLOCKED_IP_ATTEMPT
  severity String @default("INFO") // INFO, WARNING, CRITICAL

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  videoId   String?
  sessionId String?
  ipAddress String?
  referer   String?

  // Additional context as JSON
  details Json?

  // Was this event auto-blocked?
  wasBlocked Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([type, createdAt])
  @@index([severity])
}

model BlockedIP {
  id        String   @id @default(cuid())
  ipAddress String   @unique
  reason    String?
  createdAt DateTime @default(now())
  createdBy String? // Admin user ID who blocked this IP

  @@index([ipAddress])
}

model BlockedDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  reason    String?
  createdAt DateTime @default(now())
  createdBy String? // Admin user ID who blocked this domain

  @@index([domain])
}

model VideoAnalytics {
  id String @id @default(cuid())

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Event types: PAGE_VISIT, DOWNLOAD_COMPLETE
  eventType String

  // Optional: Single asset ID for individual asset downloads
  assetId String?

  // Optional: Multiple asset IDs for ZIP downloads (JSON array)
  assetIds String?

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([videoId, createdAt])
  @@index([eventType])
  @@index([assetId])
}

model SharePageAccess {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Authentication method used: OTP, PASSWORD, GUEST
  accessMethod String

  // Email address (only for OTP authentication)
  email String?

  // JWT session ID for unique session tracking
  sessionId String

  // Client metadata
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([projectId, accessMethod])
  @@index([sessionId])
}

model PasskeyCredential {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // WebAuthn credential data (following SimpleWebAuthn patterns)
  credentialID Bytes  @unique // Authenticator's credential ID
  publicKey    Bytes // Public key for signature verification
  counter      BigInt // Signature counter (prevents replay attacks)

  // UX and security metadata
  transports     String[] // ['internal', 'usb', 'nfc', 'ble', 'hybrid']
  deviceType     String // 'singleDevice' | 'multiDevice' (cloud-synced passkey)
  backedUp       Boolean  @default(false) // Indicates key material is backed up
  aaguid         String? // Authenticator Attestation GUID (optional)
  userAgent      String? // Browser/device info for admin reference
  credentialName String? // User-friendly name: "MacBook Touch ID", "iPhone Passkey"

  // Security tracking
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  lastUsedIP String?

  @@index([userId])
  @@index([userId, lastUsedAt])
}

model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint String @unique

  // Web Push subscription keys
  p256dh String
  auth   String

  // Device metadata for management UI
  userAgent  String?
  deviceName String?

  // Event subscriptions (default: all events)
  subscribedEvents String[] @default(["SHARE_ACCESS", "ADMIN_ACCESS", "CLIENT_COMMENT", "VIDEO_APPROVAL", "CLIENT_UPLOAD", "SECURITY_ALERT"])

  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@index([userId])
}

model EmailTemplate {
  id          String  @id @default(cuid())
  type        String  @unique // NEW_VERSION, PROJECT_APPROVED, COMMENT_NOTIFICATION, etc.
  name        String // Human-readable name for the template
  description String? // Description of when this template is used

  // Template content
  subject     String // Email subject line (supports placeholders)
  bodyContent String // HTML body content (supports placeholders)

  // Status flags
  isCustom Boolean @default(true) // false = system default, true = user customized
  enabled  Boolean @default(true) // Allow disabling specific templates

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, enabled])
}

// Client Directory - Companies/Organizations
model ClientCompany {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts ClientContact[]
  projects Project[]
}

// Calendar Token - Per-user iCal feed authentication
model CalendarToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// 2.4.0+: Frame.io-style URL shortener.
///
/// Stores a tidy random slug → long signed URL mapping so the admin
/// can share `https://fcmt.io/aBc12XyZ` instead of a 200-character
/// HMAC monster. Resolution is one DB read on the short-link domain
/// (e.g. `fcmt.io`) plus a 302 redirect — no auth required, the
/// downstream URL carries its own signature + expiry.
///
/// `expiresAt` is copied from the share's expiration at creation
/// time (e.g. a project share that expires in 7 days yields a short
/// link that also dies in 7 days). NULL = no expiry (share lives
/// forever, so does the short link).
///
/// Click tracking intentionally omitted in 2.4.0 per user request —
/// we can add a `clicks` counter + last-access columns later without
/// breaking anything.
model ShortLink {
  id        String    @id @default(cuid())
  slug      String    @unique
  targetUrl String    @db.Text
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([slug])
  @@index([expiresAt])
}

// Client Directory - Individual Contacts
model ClientContact {
  id        String   @id @default(cuid())
  companyId String
  company   ClientCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  language  String?  // Preferred language for emails (null = use system default)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([email])
}
